% vymazani prostredi
clear; clc; close all;

% nastaveni cesty k datasetu
dataobr = "/Users/dominikzlamal/Desktop/data";

% nacitani obrazku ze slozek, kazda slozka vytvari tridu
tridyobr = imageDatastore(dataobr, ...
    'IncludeSubfolders', true, ...
    'LabelSource', 'foldernames', ...
    'FileExtensions', {'.jpg','.jpeg','.png','.JPG','.JPEG','.PNG'});

% filtrovani trid s mensim poctem obrazku
tab = countEachLabel(tridyobr);
prah = 20;
dobreTridy = tab.Label(tab.Count >= prah);
idx = ismember(tridyobr.Labels, dobreTridy);
tridyobr = subset(tridyobr, idx);

% vypsani trid ktere splnily podminku pro min. pocet a nasledne vypsani jejich poctu
disp('Zachované třídy (>= 20 obrázků):');
disp(categories(tridyobr.Labels));
disp('Tridy: ');
disp(categories(tridyobr.Labels))

disp('Pocet obrazku v jednotlivych tridach: ')
countEachLabel(tridyobr)

disp('Pocet trid: ')
pocettrid = numel(categories(tridyobr.Labels));
disp(pocettrid)

% rozdeleni dat na trenovaci a validacni cast
[obrtrenink, obrvalidace] = splitEachLabel(tridyobr, 0.7, 'randomized');

% vypsani poctu obrazku v trenovaci a validacni sade
disp('trenovaci sada')
countEachLabel(obrtrenink)
disp('validacni sada')
countEachLabel(obrvalidace)

% nacteni predtrenovane CNN site
dataSite = load('trenovaciNet.mat');
sitCNN = dataSite.trenovaciNetw;

% zmena velikosti vstupnich dat podle pozadavku site
velikostVstupu = sitCNN.Layers(1).InputSize(1:2);
treninkProSit = augmentedImageDatastore(velikostVstupu, obrtrenink, 'ColorPreprocessing','gray2rgb');
validaceProSit = augmentedImageDatastore(velikostVstupu, obrvalidace, 'ColorPreprocessing','gray2rgb');

% extrakce priznaku z vrstvy fc7
priznakyTrenink = activations(sitCNN, treninkProSit, 'fc7', 'OutputAs','rows');
priznakyValidace = activations(sitCNN, validaceProSit, 'fc7', 'OutputAs','rows');

% nacteni trid z trenovacich dat
tridyTrenink = obrtrenink.Labels;

% nacteni trid z validacnich dat
tridyValidace = obrvalidace.Labels;

% odstraneni nepouzivanych kategorii z trenovacich trid
tridyTrenink = removecats(tridyTrenink);

% odstraneni nepouzivanych kategorii z validacnich trid
tridyValidace = removecats(tridyValidace);

% spocitani poctu vzorku v jednotlivych tridach
poctyTrid = countcats(tridyTrenink);

% prevedeni poctu trid do sloupcoveho vektoru
poctyTrid = poctyTrid(:);

% pojistka proti nulam
maskaPlatne = poctyTrid > 0;
poctyPlatne = poctyTrid(maskaPlatne);

% vypocteni vah podle poctu vzorku
prior = max(poctyPlatne) ./ poctyPlatne;

% normalizace vah tak, aby jejich soucet byl roven 1
prior = prior / sum(prior);

% ziskani nazvu jednotlivych trid
nazvyTrid = categories(tridyTrenink);

% ponechani pouze platnych trid s nenulovym poctem vzorku
nazvyTrid = nazvyTrid(maskaPlatne);

% nastaveni svm klasifikatoru s linearnim jadrem
nastaveniSVM = templateSVM('KernelFunction','linear','Standardize',true);

% natrenovani vice tridniho SVM modelu nad priznaky z CNN
modelSVM = fitcecoc(priznakyTrenink, tridyTrenink, ...
    'Learners', nastaveniSVM, ...
    'ClassNames', nazvyTrid, ...
    'Prior', prior);

% predikce trid pro validacni data
predikce = predict(modelSVM, priznakyValidace);

% vypocet presnosti modelu, ktery je udavany v procentech
presnost = mean(predikce == tridyValidace) * 100;

% vypsani dosazene presnosti
disp(['Přesnost (CNN fc7 + SVM): ', num2str(presnost,'%.2f'), ' %']);

% sjednoceni kategorii pro spravne vykresleni matice zamen
tridyValidaceCat = categorical(tridyValidace, categories(tridyTrenink));
predikceCat = categorical(predikce, categories(tridyTrenink));

% vykresleni matice zamen
confusionchart(tridyValidaceCat, predikceCat);
title('CNN (fc7) + SVM');

% ulozeni modelu a vysledku do souboru
save('svm_fc7_model_simple.mat', ...
    'modelSVM', 'presnost', 'nazvyTrid', 'prior', ...
    'tridyValidaceCat', 'predikceCat', 'prah');
